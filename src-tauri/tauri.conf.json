{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Brain Avatar",
  "version": "0.1.5",
  "identifier": "com.moil.brainavatar",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Brain Avatar",
        "width": 420,
        "height": 640,
        "minWidth": 180,
        "minHeight": 32,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false,
        "skipTaskbar": false,
        "center": false,
        "visible": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Moil-Code/brain-avatar/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZDNUU2NDI4QzJEQTM4MUEKUldRYU9OckNLR1JlL0tvVms4ODBIU2lpSnpNcEZ3bHVKVTJra2lGUTY5WUVnVDFiM2FtZW9XWEsK"
    }
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/speak-helper"
    ],
    "createUpdaterArtifacts": true,
    "targets": [
      "app",
      "dmg"
    ],
    "category": "Productivity",
    "shortDescription": "Floating local-AI brain avatar",
    "longDescription": "A floating desktop avatar that answers questions about your brain, calendar, and the web using your local LM Studio models.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "Brain Avatar Code Signing",
      "entitlements": "entitlements.plist"
    }
  }
}
