<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Hardened-runtime exception: allow microphone capture (voice input via
       WKWebView getUserMedia). Without this, a signed/hardened build blocks the
       mic at the entitlement level regardless of the TCC prompt. -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
