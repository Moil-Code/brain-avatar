# Copy to training/train.env and fill in. Sourced by auto-train.sh so scheduled
# (launchd) and by-hand runs share one config. train.env is gitignored.

# REQUIRED: MLX-format Gemma 4 12B base for mlx_lm.lora (NOT the GGUF you serve in
# LM Studio — training needs MLX weights). An mlx-community repo or a local path.
BASE_MODEL=mlx-community/gemma-4-12b-it-4bit

# Eval gate (optional but recommended): point at LM Studio serving the model so the
# frozen eval suite can block a regressing adapter.
LMSTUDIO_URL=http://localhost:1234/v1
MODEL=gemma-4-12b

# Optional knobs (defaults shown).
MODE=sft          # sft | kto
ITERS=600
NUM_LAYERS=8      # raise for more LoRA depth on the larger model

# Set to 1 to also export a quantized GGUF of the fused model for lean serving on
# 24GB (best-effort; needs llama.cpp — see train.sh / README). Leave unset to skip.
# EXPORT_GGUF=1
# LLAMACPP_DIR=/opt/homebrew/opt/llama.cpp   # or wherever llama-quantize lives
